LOAD R0 1 ; position x

LOAD R4 25 ; max x
LOAD R5 1 ; min x

LOAD R6 3 ; max reversals
LOAD R7 0 ; reversal count

CALL moveright

HALT

moveright:
   INC R0
   PRINT R0

   CMP R0 R4
   JZ reverseleft

   JMP moveright
   RET


reverseleft:
   INC R7

   CMP R7 R6
   JZ done

moveleft:
   DEC R0
   PRINT R0

   CMP R0 R5
   JZ moveright

   JMP moveleft
   RET


done:
   RET